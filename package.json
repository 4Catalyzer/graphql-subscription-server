{
  "name": "@4c/graphql-subscription-server",
  "version": "4.0.0",
  "type": "module",
  "packageManager": "yarn@4.12.0",
  "author": {
    "name": "4Catalyzer"
  },
  "license": "MIT",
  "main": "lib/index.js",
  "exports": {
    ".": "./lib/index.js",
    "./*": "./lib/*.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/4Catalyzer/graphql-subscription-server.git"
  },
  "scripts": {
    "build": "tsc",
    "format": "4c format --prettier-ignore .eslintignore .",
    "lint": "4c lint --prettier-ignore .eslintignore .",
    "prepublishOnly": "yarn run build",
    "release": "4c release",
    "tdd": "yarn testonly --watch",
    "test": "yarn lint && yarn typecheck && yarn testonly",
    "testonly": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "typecheck": "tsc --noEmit && tsc -p test --noEmit"
  },
  "gitHooks": {
    "pre-commit": "lint-staged"
  },
  "lint-staged": {
    "*": "4c lint --fix --prettier-ignore .eslintignore"
  },
  "prettier": {
    "printWidth": 79,
    "singleQuote": true,
    "trailingComma": "all"
  },
  "jest": {
    "roots": [
      "<rootDir>/test"
    ],
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1",
      "^redis$": "<rootDir>/test/__mocks__/redis.ts"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/test/setup.ts"
    ]
  },
  "release": {
    "publishDir": "lib",
    "conventionalCommits": true
  },
  "dependencies": {
    "express": "^5.2.1",
    "redis": "^5.10.0"
  },
  "peerDependencies": {
    "graphql": ">=16.0.0",
    "socket.io": ">2.0.0"
  },
  "peerDependenciesMeta": {
    "socket.io": {
      "optional": true
    }
  },
  "devDependencies": {
    "@4c/cli": "^4.0.4",
    "@4c/graphql-relay-subscription": "^0.4.0",
    "@4c/prettier-config": "^1.1.0",
    "@4c/tsconfig": "^0.4.1",
    "@jest/globals": "^30.2.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint-config-4catalyzer": "^1.5.0",
    "eslint-config-4catalyzer-jest": "^2.3.0",
    "eslint-config-4catalyzer-typescript": "^3.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.14.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "graphql": "^16.12.0",
    "graphql-relay": "^0.10.2",
    "hookem": "^3.0.4",
    "jest": "^30.2.0",
    "jsonwebtoken": "^9.0.3",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "redis-mock": "^0.56.3",
    "semantic-release": "^25.0.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "travis-deploy-once": "^5.0.11",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "utility-types": "^3.11.0"
  },
  "engines": {
    "node": ">=v24.0.0"
  },
  "bugs": {
    "url": "https://github.com/4Catalyzer/graphql-subscription-server/issues"
  },
  "readme": "ERROR: No README data found!",
  "homepage": "https://github.com/4Catalyzer/graphql-subscription-server#readme"
}
